setwd("C:/Users/purna/OneDrive/Desktop/solar_energy_prediction")
# ---------------- LOAD LIBRARIES ----------------
library(readr)
library(dplyr)
library(randomForest)
library(xgboost)
# ---------------- LOAD DATA ----------------
data <- read_csv("data/solar_data_clean.csv")
cat("Data Loaded Successfully\n")
print(head(data))
# ---------------- CLEAN DATA ----------------
data <- na.omit(data)
# ---------------- FEATURES ----------------
features <- c(
"irradiance_ghi",
"ambient_temp",
"cloud_cover_pct",
"wind_speed",
"humidity_pct",
"hour",
"month"
)
X <- data[, features]
y <- data$ac_power_kw
# ---------------- TRAIN TEST SPLIT ----------------
set.seed(42)
train_index <- sample(1:nrow(data), 0.8 * nrow(data))
train <- data[train_index, ]
test <- data[-train_index, ]
# ---------------- RANDOM FOREST ----------------
rf_model <- randomForest(ac_power_kw ~ ., data = train[, c(features, "ac_power_kw")])
rf_pred <- predict(rf_model, test)
# ---------------- XGBOOST ----------------
train_matrix <- model.matrix(ac_power_kw ~ . -1, data = train[, c(features, "ac_power_kw")])
test_matrix <- model.matrix(ac_power_kw ~ . -1, data = test[, c(features, "ac_power_kw")])
dtrain <- xgb.DMatrix(data = train_matrix, label = train$ac_power_kw)
dtest <- xgb.DMatrix(data = test_matrix, label = test$ac_power_kw)
xgb_model <- xgboost(
data = dtrain,
nrounds = 50,
objective = "reg:squarederror",
verbose = 0
)
xgb_pred <- predict(xgb_model, dtest)
# ---------------- EVALUATION ----------------
mae <- function(actual, pred) mean(abs(actual - pred))
rmse <- function(actual, pred) sqrt(mean((actual - pred)^2))
cat("\nRandom Forest Results:\n")
cat("MAE:", mae(test$ac_power_kw, rf_pred), "\n")
cat("RMSE:", rmse(test$ac_power_kw, rf_pred), "\n")
cat("\nXGBoost Results:\n")
cat("MAE:", mae(test$ac_power_kw, xgb_pred), "\n")
cat("RMSE:", rmse(test$ac_power_kw, xgb_pred), "\n")
# ---------------- SAVE OUTPUT ----------------
results <- data.frame(
Actual = test$ac_power_kw,
RF_Predicted = rf_pred,
XGB_Predicted = xgb_pred
)
write.csv(results, "outputs/final_output.csv", row.names = FALSE)
cat("\nOutput saved → outputs/final_output.csv\n")
list.files()
